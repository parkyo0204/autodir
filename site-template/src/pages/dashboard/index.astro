---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'AutoDir Dashboard';
const description = 'Process tracking and decision log for AutoDir automation pipeline';
---

<BaseLayout title={title} description={description}>
  <div class="dashboard" id="dashboard">
    <h1>AutoDir Dashboard</h1>
    <p class="subtitle">Process tracking & decision log</p>

    <section class="status-section">
      <h2>System Status</h2>
      <div class="status-grid" id="status-grid">
        <div class="status-card"><span class="status-label">Loading...</span></div>
      </div>
    </section>

    <section class="pipeline-section">
      <h2>Pipeline Steps</h2>
      <div class="pipeline-flow" id="pipeline-flow"></div>
    </section>

    <section class="niches-section">
      <h2>Top Niches</h2>
      <table class="niches-table" id="niches-table">
        <thead><tr><th>#</th><th>Keyword</th><th>Score</th><th>Recommendation</th><th>Subdomain</th></tr></thead>
        <tbody></tbody>
      </table>
    </section>

    <section class="decisions-section">
      <h2>Decision Log</h2>
      <div class="decisions-list" id="decisions-list"></div>
    </section>
  </div>

  <script is:inline>
    async function loadDashboard() {
      try {
        const [pRes, nRes, dRes] = await Promise.all([
          fetch('/data/pipeline_report.json').then(r => r.json()).catch(() => ({steps:{}})),
          fetch('/data/scored_niches.json').then(r => r.json()).catch(() => ({niches:[]})),
          fetch('/data/decisions.json').then(r => r.json()).catch(() => ({decisions:[]})),
        ]);
        const steps = pRes.steps || {};
        const entries = Object.entries(steps);
        const ok = entries.filter(([_, v]) => v.status === 'success').length;
        document.getElementById('status-grid').innerHTML = [
          {icon: ok === entries.length ? '✅' : '⚠️', label: 'Pipeline', value: ok + '/' + entries.length + ' steps OK'},
          {icon: '📊', label: 'Niches Found', value: nRes.total_signals_analyzed || 0},
          {icon: '🕐', label: 'Last Run', value: pRes.completed_at ? new Date(pRes.completed_at).toLocaleString() : 'N/A'},
          {icon: '📝', label: 'Decisions', value: (dRes.decisions || []).length},
        ].map(c => '<div class="status-card"><span class="status-icon">' + c.icon + '</span><span class="status-label">' + c.label + '</span><span class="status-value">' + c.value + '</span></div>').join('');
        document.getElementById('pipeline-flow').innerHTML = entries.map(([n, d]) => '<div class="step ' + d.status + '"><span class="step-name">' + n + '</span><span class="step-status">' + d.status + '</span>' + (d.count ? '<span class="step-detail">' + d.count + ' items</span>' : '') + '</div>').join('');
        const niches = (nRes.niches || []).slice(0, 10);
        document.querySelector('#niches-table tbody').innerHTML = niches.map((n, i) => {
          var cls = n.total_score >= 70 ? 'strong' : n.total_score >= 50 ? 'good' : n.total_score >= 30 ? 'moderate' : 'weak';
          return '<tr><td>' + (i+1) + '</td><td>' + n.keyword + '</td><td><span class="score ' + cls + '">' + n.total_score + '</span></td><td>' + n.recommendation + '</td><td><code>' + n.suggested_subdomain + '.zxzx.app</code></td></tr>';
        }).join('');
        document.getElementById('decisions-list').innerHTML = (dRes.decisions || []).map(d => '<div class="decision-card"><div class="decision-header"><span class="decision-id">' + d.id + '</span><span class="decision-date">' + d.date + '</span><span class="decision-status ' + d.outcome + '">' + d.outcome + '</span></div><p class="decision-question">' + d.question + '</p><p><strong>Decision:</strong> ' + d.decision + '</p><p><strong>Reason:</strong> ' + d.reason + '</p></div>').join('');
      } catch(e) { console.error('Dashboard error:', e); }
    }
    loadDashboard();
  </script>
</BaseLayout>

<style>
  .dashboard{max-width:1200px}.subtitle{color:var(--color-muted);margin-bottom:2rem}.status-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-top:1rem}.status-card{background:#f9fafb;border:1px solid var(--color-border);border-radius:.75rem;padding:1.25rem;display:flex;flex-direction:column;gap:.5rem}.status-icon{font-size:1.5rem}.status-label{font-size:.875rem;color:var(--color-muted)}.status-value{font-size:1.25rem;font-weight:600}.pipeline-section,.niches-section,.decisions-section{margin:2rem 0}.pipeline-flow{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem}.step{padding:.75rem 1rem;border-radius:.5rem;border:1px solid var(--color-border);display:flex;flex-direction:column;gap:.25rem;min-width:150px}.step.success{background:#f0fdf4;border-color:#86efac}.step.error{background:#fef2f2;border-color:#fca5a5}.step.skipped{background:#f9fafb;opacity:.7}.step-name{font-weight:600;text-transform:capitalize}.step-status{font-size:.75rem;color:var(--color-muted)}.step-error{font-size:.75rem;color:#ef4444}.niches-table{width:100%;border-collapse:collapse;margin-top:1rem}.niches-table th,.niches-table td{padding:.75rem 1rem;border:1px solid var(--color-border);text-align:left}.niches-table th{background:#f9fafb;font-weight:600}.score{font-weight:700;padding:.125rem .5rem;border-radius:.25rem}.score.strong{background:#dcfce7;color:#166534}.score.good{background:#dbeafe;color:#1e40af}.score.moderate{background:#fef3c7;color:#92400e}.score.weak{background:#fee2e2;color:#991b1b}.decisions-list{display:flex;flex-direction:column;gap:1rem;margin-top:1rem}.decision-card{border:1px solid var(--color-border);border-radius:.75rem;padding:1.25rem}.decision-header{display:flex;gap:.75rem;align-items:center;margin-bottom:.75rem}.decision-id{font-weight:700;font-family:monospace}.decision-date{color:var(--color-muted);font-size:.875rem}.decision-status{font-size:.75rem;padding:.125rem .5rem;border-radius:1rem}.decision-status.validated{background:#dcfce7;color:#166534}.decision-status.pending{background:#fef3c7;color:#92400e}.decision-question{font-style:italic;color:var(--color-muted);margin-bottom:.5rem}
</style>
